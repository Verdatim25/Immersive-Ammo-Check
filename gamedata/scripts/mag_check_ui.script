-- alot of this is from NERFS. Many thanks to Catspaw

function MagCheckUI:InitControls(xmlfile,element,texture,pos)
    self.pos = pos or {x=491,y=670}
    self:SetAutoDelete(true)
    self.xml        = CScriptXmlInit()
    self.xml:ParseFile(xmlfile or "mag_check_ui.xml")
    self.background  = self.xml:InitStatic(element or "mag_check_ui:background",self)
    self.text  = self.xml:InitTextWnd("mag_check_ui:background:text", self.background)
    -- if texture then self.text:InitTexture(texture) end
	self.text:SetText("texttexttext")
    self.background:SetWndPos(vector2():set(self.pos.x, self.pos.y))
