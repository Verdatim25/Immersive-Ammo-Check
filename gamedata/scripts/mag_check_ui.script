-- disabling ammo check message unless there isnt an animation

-- ammo_check_mcm.actor_menu = tbl

original_ammo_check = ammo_check_mcm.check_Ammo

ammo_check_mcm.check_Ammo = function()
	local wpn = db.actor:active_item()
	original_ammo_check()
	if not (wpn and wpn:is_weapon()) then return end
	if animation_common.has_animation(wpn:section(), "anm_ammo_check") then
		RemoveTimeEvent("ammo_check", "restore Weapon")
		RemoveTimeEvent("ammo_check", "message delay")
	end
end



