local update = 100
local timer = 0

function actor_on_update()
	local tg = time_global()
	if (tg < timer) then
		return
	else
		timer = tg + update
	end
	local wpn = db.actor:active_item()
	--local wpn_sec = wpn and wpn:section()
	local wpn_cast = wpn and wpn:is_weapon() and wpn:cast_Weapon()
	if not wpn_cast then return end
	local ammo_type = wpn_cast:GetAmmoType()
	local ammo_types = {}
	wpn_cast:AmmoTypeForEach(function(i, ammo_sec)
		ammo_types[i] = ammo_sec
	end)
	ammo_type = ammo_types[ammo_type] or 0
	local ammo_str_name = ini_sys:r_string_ex(ammo_type, "inv_name_short")
	if ammo_str_name then
		ammo_str_name = game.translate_string(ammo_str_name)
	else
		ammo_str_name = ammo_type
	end
	local curr_ammo_count = wpn_cast:GetAmmoElapsed() or 0
	local max_ammo_count = wpn_cast:GetAmmoMagSize() or 30
	local text = string.format("%s/%s %s", curr_ammo_count, max_ammo_count, ammo_str_name)
	
	self = HUD
	if not false then return end
	
	printf("tried to set text to %s", text)
	
	-- local mag_pos = wpn:bone_position("magazin", true)
	-- printf("mag_pos is %s", mag_pos)
	
	
	self.window_text:SetText(text)
	
	-- time to find the position for the mag bone
	local hud_mag_pos = wpn:bone_position("magazin", true)
	local world_mag_pos = hud_mag_pos:hud_to_world()
	local ui_mag_pos = game.world2ui(world_mag_pos, false, false)
	
	printf("set ui_pos to %s", ui_mag_pos)
	
	self.window_text:SetWndPos(ui_mag_pos)
end

HUD = nil

function show_hud()
	if HUD == nil then
		HUD = MagCheckUI() -- calls instance of your HUD class
	end
	
	if HUD and not HUD:IsShown() then
		get_hud():AddDialogToRender(HUD) -- renders HUD on screen
		Register_UI("MagCheckUI", "mag_check_ui", HUD)
	end
	return HUD
end


function close_hud()
	if HUD and HUD:IsShown() then
		get_hud():RemoveDialogToRender(HUD)
		Unregister_UI("MagCheckUI")
		HUD = nil -- optional, destroys HUD instance
	end
end

function check_for_mag_check_anim(anim_table, obj)
	if string.find(anim_table.anm_name, "ammo_check") then
		printf("showing hud")
		show_hud()
	else
		printf("hiding hud")
		close_hud()
	end
end

if animation_common then
	animation_common.add_anim_mutator(check_for_mag_check_anim, 100)
end

function on_game_start()
	if not animation_common then
		RegisterScriptCallback("actor_on_hud_animation_play", check_for_mag_check_anim)
	end
	RegisterScriptCallback("actor_on_net_destroy", close_hud)
	
	RegisterScriptCallback("actor_on_update", actor_on_update)
end

]=]
