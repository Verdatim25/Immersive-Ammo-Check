	self.background:Show(true)
    --self.text:EnableHeading(true)
    --self.text:SetConstHeading(true)
    self.text:Show(true)
    self:ShowMagText(true)
end

function MagCheckUI:ShowMagText(onoff)
	self.text:Show(onoff)
end

function MagCheckUI:__finalize() 
end

